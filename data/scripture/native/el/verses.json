[{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.24","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ἕκαστος ἐν ᾧ ἐκλήθη, ἀδελφοί, ἐν τούτῳ μενέτω παρὰ τῷ Θεῷ.","text_sha256":"2c5453170b6decbe9e789d8c7a756919c5d392623f9b9a76af4a7e41db332731","verse":24},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.25","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"Περὶ δὲ τῶν παρθένων ἐπιταγὴν Κυρίου οὐκ ἔχω, γνώμην δὲ δίδωμι ὡς ἠλεημένος ὑπὸ Κυρίου πιστὸς εἶναι.","text_sha256":"c23a0dc0be0d7a349ed2338026e3554652a9ea71214e560127e568cf31baa341","verse":25},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.26","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"νομίζω οὖν τοῦτο καλὸν ὑπάρχειν διὰ τὴν ἐνεστῶσαν ἀνάγκην, ὅτι καλὸν ἀνθρώπῳ τὸ οὕτως εἶναι.","text_sha256":"2bf675491471d52cd283daa2e3068e3468ed38198900ba2b4cadca3d79d68c78","verse":26},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.27","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"δέδεσαι γυναικί; μὴ ζήτει λύσιν· λέλυσαι ἀπὸ γυναικός; μὴ ζήτει γυναῖκα·","text_sha256":"a9a72c2255add753fb31f1a4a1f914c0a5a2142852d4f4f06354e86b6fd4b42a","verse":27},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.28","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ἐὰν δὲ καὶ γήμῃς, οὐχ ἥμαρτες· καὶ ἐὰν γήμῃ ἡ παρθένος, οὐχ ἥμαρτε· θλῖψιν δὲ τῇ σαρκὶ ἕξουσιν οἱ τοιοῦτοι· ἐγὼ δὲ ὑμῶν φείδομαι.","text_sha256":"7fbf26da90025e8fa5091a8094a911a46fcb727029031ed32c86a8e887e685db","verse":28},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.29","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"τοῦτο δέ φημι, ἀδελφοί, ὁ καιρὸς συνεσταλμένος τὸ λοιπόν ἐστιν, ἵνα καὶ οἱ ἔχοντες γυναῖκας ὡς μὴ ἔχοντες ὦσι,","text_sha256":"59779fe6978ec0762f72962dda0413e511f6857b1dca327f5bafa80256f3bbb5","verse":29},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.30","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"καὶ οἱ κλαίοντες ὡς μὴ κλαίοντες, καὶ οἱ χαίροντες ὡς μὴ χαίροντες, καὶ οἱ ἀγοράζοντες ὡς μὴ κατέχοντες,","text_sha256":"a81d32ce10562ce021459922de3a29f3380ea20ed722c746b318c6cab487a3ba","verse":30},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.31","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"καὶ οἱ χρώμενοι τῷ κόσμῳ τούτῳ ὡς μὴ καταχρώμενοι· παράγει γὰρ τὸ σχῆμα τοῦ κόσμου τούτου.","text_sha256":"817e36a58185740edecb47a12178316f2b8a3d2ca49a766ced7f4255dd7edaf3","verse":31},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.32","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"θέλω δὲ ὑμᾶς ἀμερίμνους εἶναι. ὁ ἄγαμος μεριμνᾷ τὰ τοῦ Κυρίου, πῶς ἀρέσει τῷ Κυρίῳ·","text_sha256":"bf0f6795031e545b195399589918af2cb4f49512c732bafcdcee0820dc9e26aa","verse":32},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.33","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ὁ δὲ γαμήσας μεριμνᾷ τὰ τοῦ κόσμου, πῶς ἀρέσει τῇ γυναικί.","text_sha256":"b1e92e20a7766ea7aeb860e41062bc2e76d297a7d2eeaae80c2a1b9934b2c1a8","verse":33},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.34","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"μεμέρισται [καὶ] ἡ γυνὴ καὶ ἡ παρθένος. ἡ ἄγαμος μεριμνᾷ τὰ τοῦ Κυρίου, ἵνα ᾖ ἁγία καὶ σώματι καὶ πνεύματι· ἡ δὲ γαμήσασα μεριμνᾷ τὰ τοῦ κόσμου, πῶς ἀρέσει τῷ ἀνδρί.","text_sha256":"87fcaf3ede766f2eb343950cb9ffec40f3f8902deb093e843bd124b310b3ecd4","verse":34},{"automatic_diacritization_used":false,"book_id":"1CO","book_name":"ΠΡΟΣ ΚΟΡΙΝΘΙΟΥΣ Α΄","chapter":7,"id":"1CO.7.35","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"τοῦτο δὲ πρὸς τὸ ὑμῶν αὐτῶν συμφέρον λέγω, οὐχ ἵνα βρόχον ὑμῖν ἐπιβάλω, ἀλλὰ πρὸς τὸ εὔσχημον καὶ εὐπάρεδρον τῷ Κυρίῳ ἀπερισπάστως.","text_sha256":"b5402f7bcc719567a10365f0832769101421c5f9ee35b40df031efefb4898b43","verse":35},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.12","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"τότε προσελθόντες οἱ μαθηταὶ αὐτοῦ εἶπον αὐτῷ· οἶδας ὅτι οἱ Φαρισαῖοι ἐσκανδαλίσθησαν ἀκούσαντες τὸν λόγον;","text_sha256":"1e6947916535440497428b96e9eb999730835bd086ffe67ba7317265eaca9102","verse":12},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.13","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ὁ δὲ ἀποκριθεὶς εἶπε· πᾶσα φυτεία ἣν οὐκ ἐφύτευσεν ὁ πατήρ μου ὁ οὐράνιος ἐκριζωθήσεται.","text_sha256":"f9c29229392230e858bb2edb8e892259efab3c25bf867a807603b2d05f7a1183","verse":13},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.14","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ἄφετε αὐτούς· ὁδηγοί εἰσι τυφλοὶ τυφλῶν· τυφλὸς δὲ τυφλὸν ἐὰν ὁδηγῇ, ἀμφότεροι εἰς βόθυνον πεσοῦνται.","text_sha256":"e0732507c5db9a3686504ebd7f2dcd540691602965379ce692c2ec0062964864","verse":14},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.15","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ἀποκριθεὶς δὲ ὁ Πέτρος εἶπεν αὐτῷ· φράσον ἡμῖν τὴν παραβολὴν ταύτην.","text_sha256":"c1e9018feb981fa94a7f5dadd32d8c2a987ef0c5c9d7e2068dadee36ecdb3318","verse":15},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.16","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ὁ δὲ Ἰησοῦς εἶπεν· ἀκμὴν καὶ ὑμεῖς ἀσύνετοί ἐστε;","text_sha256":"d027e76be6ec4da487c258c1599871828057dd4d42e4f4655ee5e47466181831","verse":16},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.17","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"οὔπω νοεῖτε ὅτι πᾶν τὸ εἰσπορευόμενον εἰς τὸ στόμα εἰς τὴν κοιλίαν χωρεῖ καὶ εἰς ἀφεδρῶνα ἐκβάλλεται;","text_sha256":"5ee02985c8beb43bd04488113b7396f988d14b27f375a5ace7a8b019c3e99656","verse":17},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.18","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"τὰ δὲ ἐκπορευόμενα ἐκ τοῦ στόματος ἐκ τῆς καρδίας ἐξέρχεται, κἀκεῖνα κοινοῖ τὸν ἄνθρωπον.","text_sha256":"3e8796ffaa98878a04b4283d30b6f7d4110d9f5d47a4662abac60110fff33a8b","verse":18},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.19","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ἐκ γὰρ τῆς καρδίας ἐξέρχονται διαλογισμοὶ πονηροί, φόνοι, μοιχεῖαι, πορνεῖαι, κλοπαί, ψευδομαρτυρίαι, βλασφημίαι.","text_sha256":"0d66ddd1765df7f7040f4821dc4ce11263545762dadaf6a1d6acac1fc337d05d","verse":19},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.20","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"ταῦτά ἐστι τὰ κοινοῦντα τὸν ἄνθρωπον· τὸ δὲ ἀνίπτοις χερσὶ φαγεῖν οὐ κοινοῖ τὸν ἄνθρωπον.","text_sha256":"bafd1b54921c7e6a30b95582fd932fbb81f8425fe28f20b00b1876eb4de7895e","verse":20},{"automatic_diacritization_used":false,"book_id":"MAT","book_name":"ΚΑΤΑ ΜΑΤΘΑΙΟΝ","chapter":15,"id":"MAT.15.21","machine_translation_used":false,"source_id":"ebible_greek_byzantine_1904","source_url":"https://ebible.org/find/details.php?id=grcbyz","text":"Καὶ ἐξελθὼν ἐκεῖθεν ὁ Ἰησοῦς ἀνεχώρησεν εἰς τὰ μέρη Τύρου καὶ Σιδῶνος.","text_sha256":"0db30b63d4ff41acf4a521314be38e7fe40cb4bcd2afe3adaca791102523686d","verse":21}]
