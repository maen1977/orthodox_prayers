.gradle/
build/
app/build/
release/
local.properties
*.iml
.DS_Store
__pycache__/
.pytest_cache/
*.py[cod]

# Runtime canonical download cache
.cache/

# Never commit Android signing material
*.jks
*.keystore
*.p12
*.pem
keystore.properties

# Data-signing secrets must remain outside the repository
*_PRIVATE_KEY*
*private*.key
*private*.der
*.key

# Detached public signatures and public keys are committed intentionally

# Generated validation and handoff output
reports/
FILE_SHA256SUMS.txt
VERIFICATION_AR.txt
*.zip.sha256

# Licensed raw source exports and permission documents stay outside the public repository
private-source-bundles/
permission-documents/
authorized-source-snapshots/

# Explicitly reject the private handoff bundle files
GITHUB_SECRETS.txt
android-signing/
data-signing/*PRIVATE*
اقرأني-أولا-الحزمة-الكاملة.txt
