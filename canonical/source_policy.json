{
  "schema_version": 5,
  "mode": "strict_fail_closed",
  "calendar": "julian_old_calendar",
  "jurisdiction": "Greek Orthodox Patriarchate of Jerusalem — Jordan priority",
  "publication": {
    "human_review_required": false,
    "publish_only_when": "AUTOMATIC_NATIVE_LANGUAGE_POLICY_ENFORCED",
    "on_uncertainty": "BLOCK_AND_KEEP_LAST_SIGNED_GOOD",
    "never_mix_liturgical_traditions_silently": true,
    "never_generate_scripture_or_liturgical_text_with_ai": true,
    "never_translate_between_language_lanes": true,
    "never_automatically_diacritize": true
  },
  "source_priority": [
    "orthodox_jordan",
    "jerusalem_patriarchate",
    "antioch_patriarchate",
    "official_greek_orthodox",
    "orthodox_church_in_america"
  ],
  "reference_policy": {
    "official_only": true,
    "lower_priority_used_only_when_higher_invalid_or_unavailable": true,
    "record_every_fallback_reason": true,
    "orthocal_role": "discovery_only_never_publication_authority",
    "fail_on_official_conflict": true
  },
  "scripture_canonical": {
    "mode": "PER_LANGUAGE_OFFICIAL_NATIVE_CORPUS_ONLY",
    "corpus_manifests": {
      "ar": "data/scripture/native/ar/manifest.json",
      "en": "data/scripture/native/en/manifest.json",
      "el": "data/scripture/native/el/manifest.json"
    },
    "legacy_arb_vd_snapshots": {
      "status": "QUARANTINED_NOT_PUBLICATION_AUTHORITY",
      "path": "canonical/scripture",
      "reason_ar": "تُحفظ للاختبارات التاريخية فقط ولا يجوز أن تملأ المسار العربي بعد اعتماد سياسة المصدر الكنسي العربي الأصلي."
    },
    "missing_text_behavior": "UNAVAILABLE_UNTIL_OWNER_IMPORTS_AN_APPROVED_OFFICIAL_NATIVE_CORPUS"
  },
  "liturgical_text_policy": {
    "show_complete_text_instead_of_generic_guidance": true,
    "banned_placeholder_phrases": [
      "راجع الكنيسة",
      "راجع النص الكنسي",
      "راجع كتاب الخدمة المحلي",
      "أضفه في ملف override",
      "تضاف هنا القطع",
      "تُضاف هنا القطع",
      "تُوضع الاستيخيرات",
      "تظهر الاستيخيرات والأبوستيخا هنا فقط",
      "تظهر الكاثسما والقانون والإكسابوستيلاريون فقط",
      "يمكن قراءة طروبارية وقنداق اليوم المعروضين"
    ],
    "guidance": {
      "optional_and_collapsed": true,
      "essential_only": true,
      "must_not_replace_missing_text": true
    },
    "translation_fallback": {
      "scripture": "DISABLED; SAME_LANGUAGE_OFFICIAL_NATIVE_CORPUS_ONLY",
      "liturgical": "DISABLED; EXACT_OFFICIAL_NATIVE_SOURCE_TEXT_ONLY",
      "non_orthodox_source_may_define_liturgical_order": false,
      "cross_language_fallback": false
    }
  },
  "sources": {
    "orthodox_jordan": {
      "priority": 1,
      "url": "https://orthodoxjordan.org/%D8%B5%D9%84%D8%A7%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/",
      "role": "official_local_primary",
      "reject_if_stale": true,
      "poison_markers": [
        "lorem ipsum",
        "لوريم إيبسوم",
        "لوريم ايبسوم"
      ]
    },
    "jerusalem_patriarchate": {
      "priority": 2,
      "url": "https://en.jerusalem-patriarchate.info/liturgical-life/major-feasts/",
      "role": "official_jurisdiction_and_feast_authority",
      "daily_endpoint_status": "no_stable_machine_readable_daily_endpoint"
    },
    "antioch_patriarchate": {
      "priority": 3,
      "role": "official_arabic_liturgical_guide_fallback",
      "registry": "canonical/antioch_yearbook_sources.json"
    },
    "official_greek_orthodox": {
      "priority": 4,
      "url_template": "https://www.goarch.org/chapel/calendar?month={month}&year={year}",
      "role": "official_greek_orthodox_last_fallback_for_lectionary_and_cross_check"
    },
    "orthocal_old": {
      "url_template": "https://orthocal.info/api/julian/{year}/{month}/{day}/",
      "role": "discovery_only",
      "publication_authority": false
    },
    "orthodox_church_in_america": {
      "priority": 5,
      "url_template": "https://www.oca.org/readings/daily/{year}/{month:02d}/{day:02d}",
      "role": "official_orthodox_english_lectionary_last_fallback",
      "registry": "canonical/daily_lectionary_records.json"
    }
  },
  "fasting_policy": {
    "path": "canonical/fasting_policy.json",
    "mode": "automatic_typikon_baseline_with_official_source_evidence",
    "note_ar": "يُحسب الصيام حسب التقويم القديم ويُرفق بدليل المصدر؛ التعارض الرسمي يمنع نشر التحديث الجديد."
  },
  "calendar_compatibility": {
    "required": true,
    "jerusalem_old_calendar_is_authoritative": true,
    "fixed_feasts_resolved_by_julian_month_day": true,
    "paschal_sunday_cycle_may_be_shared_only_after_fixed_feast_check": true,
    "reject_new_calendar_fixed_feast_override": true
  },
  "language_content_policy": {
    "official_site_does_not_imply_redistribution_permission": true,
    "publish_native_text_only_when_redistribution_rights_are_clear": true,
    "missing_translation_behavior": "SHOW_UNAVAILABLE; NEVER_COPY_OR_TRANSLATE",
    "arabic_primary": [
      "orthodox_jordan",
      "jerusalem_patriarchate_ar",
      "antioch_patriarchate_ar"
    ],
    "greek_primary": [
      "church_of_greece_apostoliki_diakonia",
      "church_of_greece_ecclesia",
      "jerusalem_patriarchate_el",
      "goarch_digital_chant_stand_greek"
    ],
    "english_primary": [
      "goarch_online_chapel",
      "jerusalem_patriarchate_en",
      "goarch_digital_chant_stand_english",
      "goarch_synekdemos",
      "oca_official_english"
    ],
    "translation_between_lanes_allowed": false,
    "missing_native_text_behavior": "SHOW_UNAVAILABLE; NEVER_COPY_TRANSLATE_OR_AUTOMATICALLY_DIACRITIZE"
  },
  "native_language_contract": "canonical/source_native_contract.json"
}
