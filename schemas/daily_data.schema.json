{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/maen1977/orthodox_prayers/schemas/daily_data.schema.json",
  "title": "Orthodox Prayers Daily Native-Language Data",
  "type": "object",
  "required": [
    "schema_version",
    "date_iso",
    "date_label",
    "fasting",
    "feast",
    "readings",
    "services",
    "upcoming",
    "next_sunday",
    "content_metadata",
    "integrity",
    "publication",
    "source_evidence",
    "language_content_mode",
    "language_sources",
    "native_text_contract"
  ],
  "properties": {
    "schema_version": {
      "const": 9
    },
    "date_iso": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "date_label": {
      "$ref": "#/$defs/localized"
    },
    "fast": {
      "$ref": "#/$defs/localized"
    },
    "fasting": {
      "type": "object",
      "required": [
        "code",
        "title",
        "detail",
        "is_fast",
        "allowed",
        "verification"
      ],
      "properties": {
        "code": {
          "enum": [
            "fast_free",
            "dairy_allowed",
            "fish_allowed",
            "wine_oil",
            "strict"
          ]
        },
        "title": {
          "$ref": "#/$defs/localized"
        },
        "detail": {
          "$ref": "#/$defs/localized"
        },
        "is_fast": {
          "type": "boolean"
        },
        "allowed": {
          "type": "object",
          "required": [
            "meat",
            "dairy",
            "eggs",
            "fish",
            "wine",
            "oil"
          ],
          "properties": {
            "meat": {
              "type": "boolean"
            },
            "dairy": {
              "type": "boolean"
            },
            "eggs": {
              "type": "boolean"
            },
            "fish": {
              "type": "boolean"
            },
            "wine": {
              "type": "boolean"
            },
            "oil": {
              "type": "boolean"
            }
          }
        },
        "guidance": {
          "$ref": "#/$defs/fastingGuidance"
        },
        "abstinence": {
          "$ref": "#/$defs/abstinence"
        },
        "verification": {
          "type": "object"
        }
      }
    },
    "feast": {
      "$ref": "#/$defs/localized"
    },
    "readings": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/reading"
      }
    },
    "services": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "upcoming": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7
    },
    "next_sunday": {
      "type": "object",
      "required": [
        "date_iso",
        "day",
        "fast",
        "fasting",
        "service_id"
      ]
    },
    "integrity": {
      "type": "object",
      "$comment": "The verified-source and native-text integrity envelopes may coexist after release-candidate generation; anyOf is intentional because oneOf rejects a valid combined envelope.",
      "anyOf": [
        {
          "required": [
            "status",
            "ai_scripture_translation_used",
            "ai_liturgical_translation_used"
          ],
          "properties": {
            "status": {
              "const": "VERIFIED_OFFICIAL_SOURCES"
            },
            "ai_scripture_translation_used": {
              "const": false
            },
            "ai_liturgical_translation_used": {
              "const": false
            }
          }
        },
        {
          "required": [
            "native_text_contract"
          ],
          "properties": {
            "native_text_contract": {
              "const": "canonical/source_native_contract.json"
            },
            "legacy_arabic_scripture_snapshot": {
              "type": "string"
            }
          }
        }
      ]
    },
    "publication": {
      "type": "object",
      "required": [
        "status",
        "fail_closed",
        "same_language_fallback_only",
        "religious_text_contract",
        "daily_availability",
        "human_review_required"
      ],
      "properties": {
        "status": {
          "const": "AUTOMATIC_NATIVE_LANGUAGE_POLICY_ENFORCED"
        },
        "fail_closed": {
          "const": true
        },
        "same_language_fallback_only": {
          "const": true
        },
        "religious_text_contract": {
          "const": "canonical/source_native_contract.json"
        },
        "daily_availability": {
          "enum": [
            "FULL",
            "PARTIAL_VERIFIED"
          ]
        },
        "human_review_required": {
          "const": false
        }
      }
    },
    "language_content_mode": {
      "const": "THREE_STRICTLY_INDEPENDENT_OFFICIAL_NATIVE_LANGUAGE_LANES"
    },
    "machine_translation_used": {
      "const": false
    },
    "automatic_diacritization_used": {
      "const": false
    },
    "translation_fallback_policy": {
      "const": "DISABLED_NO_CROSS_LANGUAGE_FALLBACK"
    },
    "native_text_contract": {
      "const": "canonical/source_native_contract.json"
    },
    "language_sources": {
      "type": "object",
      "required": [
        "ar",
        "en",
        "el"
      ],
      "properties": {
        "ar": {
          "$ref": "#/$defs/languageSource"
        },
        "en": {
          "$ref": "#/$defs/languageSource"
        },
        "el": {
          "$ref": "#/$defs/languageSource"
        }
      }
    },
    "source_evidence": {
      "type": "array"
    },
    "fasting_guidance_version": {
      "const": 1
    }
  },
  "$defs": {
    "localized": {
      "type": "object",
      "required": [
        "ar",
        "en",
        "el"
      ],
      "properties": {
        "ar": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "el": {
          "type": "string"
        }
      }
    },
    "languageSource": {
      "type": "object",
      "required": [
        "priority",
        "same_language_fallback_only",
        "machine_translation_used",
        "automatic_diacritization_used",
        "missing_text_behavior"
      ],
      "properties": {
        "priority": {
          "type": "array",
          "minItems": 3
        },
        "same_language_fallback_only": {
          "const": true
        },
        "machine_translation_used": {
          "const": false
        },
        "automatic_diacritization_used": {
          "const": false
        },
        "missing_text_behavior": {
          "const": "UNAVAILABLE"
        }
      }
    },
    "nativeEvidence": {
      "type": "object",
      "required": [
        "status",
        "reference_available",
        "text_available",
        "ai_translation_used",
        "automatic_diacritization_used"
      ],
      "properties": {
        "status": {
          "enum": [
            "VERIFIED_EXACT_NATIVE_SOURCE",
            "IMPORTED_EXACT_OFFICIAL_NATIVE_CORPUS",
            "IMPORTED_EXACT_PUBLIC_DOMAIN_NATIVE_CORPUS",
            "VERIFIED_EXACT_NATIVE_REFERENCE_ONLY",
            "UNAVAILABLE_UNTIL_EXACT_OFFICIAL_NATIVE_SOURCE"
          ]
        },
        "source_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference_available": {
          "type": "boolean"
        },
        "text_available": {
          "type": "boolean"
        },
        "ai_translation_used": {
          "const": false
        },
        "automatic_diacritization_used": {
          "const": false
        },
        "text_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "reading": {
      "type": "object",
      "required": [
        "kind",
        "title",
        "reference",
        "body",
        "source",
        "translation_locked",
        "integrity",
        "native_source_verification"
      ],
      "properties": {
        "kind": {
          "enum": [
            "prokeimenon",
            "epistle",
            "gospel"
          ]
        },
        "title": {
          "$ref": "#/$defs/localized"
        },
        "reference": {
          "$ref": "#/$defs/localized"
        },
        "body": {
          "$ref": "#/$defs/localized"
        },
        "source": {
          "$ref": "#/$defs/localized"
        },
        "translation_locked": {
          "const": true
        },
        "integrity": {
          "type": "object",
          "required": [
            "status",
            "ai_translation_used",
            "automatic_diacritization_used"
          ],
          "properties": {
            "status": {
              "const": "NATIVE_LANGUAGE_LANES_ENFORCED"
            },
            "ai_translation_used": {
              "const": false
            },
            "automatic_diacritization_used": {
              "const": false
            }
          }
        },
        "native_source_verification": {
          "type": "object",
          "required": [
            "ar",
            "en",
            "el"
          ],
          "properties": {
            "ar": {
              "$ref": "#/$defs/nativeEvidence"
            },
            "en": {
              "$ref": "#/$defs/nativeEvidence"
            },
            "el": {
              "$ref": "#/$defs/nativeEvidence"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "required": [
        "id",
        "category",
        "title",
        "segments"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": [
            "daily",
            "basic",
            "liturgy"
          ]
        },
        "title": {
          "$ref": "#/$defs/localized"
        },
        "segments": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "fastingGuidance": {
      "type": "object",
      "required": [
        "allowed_summary",
        "forbidden_summary",
        "duration",
        "beginner_explanation",
        "spiritual_note",
        "health_note"
      ],
      "properties": {
        "allowed_summary": {
          "$ref": "#/$defs/localized"
        },
        "forbidden_summary": {
          "$ref": "#/$defs/localized"
        },
        "duration": {
          "$ref": "#/$defs/localized"
        },
        "beginner_explanation": {
          "$ref": "#/$defs/localized"
        },
        "spiritual_note": {
          "$ref": "#/$defs/localized"
        },
        "health_note": {
          "$ref": "#/$defs/localized"
        }
      }
    },
    "abstinence": {
      "type": "object",
      "required": [
        "applies",
        "kind",
        "start_time",
        "end_time",
        "end_condition",
        "detail",
        "verification"
      ],
      "properties": {
        "applies": {
          "type": "boolean"
        },
        "kind": {
          "enum": [
            "not_indicated",
            "documented_interval",
            "until_communion",
            "until_service_end"
          ]
        },
        "start_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "end_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "end_condition": {
          "$ref": "#/$defs/localized"
        },
        "detail": {
          "$ref": "#/$defs/localized"
        },
        "verification": {
          "type": "object",
          "required": [
            "status",
            "source"
          ],
          "properties": {
            "status": {
              "enum": [
                "NOT_INDICATED",
                "DOCUMENTED_OVERRIDE"
              ]
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
