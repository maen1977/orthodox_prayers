# Keep executable scripts and ordinary source text deterministic.
* text=auto eol=lf

gradlew text eol=lf
gradlew.bat text eol=crlf

# Signed payloads and detached signatures must be stored byte-for-byte.
# Git newline normalization after signing would invalidate RSA verification.
data/calendar/*.json binary
data/calendar/*.sig binary
app/src/main/assets/data/*.json binary
app/src/main/assets/data/*.sig binary
canonical/signing/*.pub binary

*.jar binary
*.png binary
